# AI Arcade environment examples
#
# Copy only the values you need into the place that runs the app:
# - Web local dev: shell env before `pnpm --filter web dev`, or `apps/web/.env.local`
# - Realtime local dev: shell env before `pnpm --filter realtime-server dev`
# - Deployment: set these in the Vercel/Render/Fly/Railway dashboard

# Local default
NEXT_PUBLIC_REALTIME_URL=http://localhost:4000
REALTIME_PORT=4000
REALTIME_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000
DRAW_DUEL_AI_PROVIDER=mock
THREE_WORD_MONSTER_IMAGE_PROVIDER=mock
THREE_WORD_MONSTER_IMAGE_MODEL=gpt-image-2
THREE_WORD_MONSTER_IMAGE_SIZE=1024x1024
THREE_WORD_MONSTER_IMAGE_TIMEOUT_MS=120000
DISCONNECT_GRACE_MS=60000

# ngrok rehearsal example
# 1. Start local web/realtime once.
# 2. Start two ngrok tunnels for 3000 and 4000.
# 3. Restart web/realtime with the two generated HTTPS URLs below.
# NEXT_PUBLIC_REALTIME_URL=https://<realtime-ngrok-url>
# CORS_ORIGIN=https://<web-ngrok-url>

# Stable deployment example
# Vercel web:
# NEXT_PUBLIC_REALTIME_URL=https://<realtime-server-url>
#
# Realtime host:
# PORT=<platform-provided-port>
# REALTIME_PORT=<optional-override>
# REALTIME_HOST=0.0.0.0
# CORS_ORIGIN=https://<vercel-web-url>
# DRAW_DUEL_AI_PROVIDER=mock
# DISCONNECT_GRACE_MS=60000

# OpenAI provider rehearsal only.
# Do not put OPENAI_API_KEY in NEXT_PUBLIC_* variables or client-side config.
# THREE_WORD_MONSTER_IMAGE_PROVIDER=openai
# THREE_WORD_MONSTER_IMAGE_MODEL=gpt-image-2
# THREE_WORD_MONSTER_IMAGE_SIZE=1024x1024
# THREE_WORD_MONSTER_IMAGE_TIMEOUT_MS=120000
DRAW_DUEL_AI_MODEL=gpt-5
# Use gpt-5.5 only for high-accuracy eval runs if gpt-5 misses the 80% gate.
# DRAW_DUEL_AI_MODEL=gpt-5.5
DRAW_DUEL_AI_TIMEOUT_MS=10000
DRAW_DUEL_AI_DETAIL=auto
DRAW_DUEL_AI_RETRY_LIMIT=0
DRAW_DUEL_AI_BENCHMARK_MIN_ACCURACY=0.8
# Optional: limit paid benchmark samples while iterating locally.
# DRAW_DUEL_AI_BENCHMARK_SAMPLE_LIMIT=12
OPENAI_API_KEY=
