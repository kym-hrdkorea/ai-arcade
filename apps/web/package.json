{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @ai-arcade/shared build && pnpm --filter @ai-arcade/qr-code build && next dev",
    "build": "pnpm --filter @ai-arcade/shared build && pnpm --filter @ai-arcade/qr-code build && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@ai-arcade/qr-code": "workspace:*",
    "@ai-arcade/shared": "workspace:*",
    "lucide-react": "^0.468.0",
    "next": "^15.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "eslint-config-next": "^15.5.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.4"
  }
}
