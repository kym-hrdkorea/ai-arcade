{
  "name": "realtime-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @ai-arcade/shared build && tsx watch src/index.ts",
    "ai:bench": "pnpm --filter @ai-arcade/shared build && tsx src/draw-duel-ai-benchmark.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "load:smoke": "pnpm --filter @ai-arcade/shared build && tsx src/load-smoke.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @ai-arcade/shared build && vitest run src --passWithNoTests",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@ai-arcade/shared": "workspace:*",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "socket.io-client": "^4.8.3"
  }
}
